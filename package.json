{
  "name": "x402-api-marketplace",
  "version": "1.0.0",
  "description": "零成本构建、部署和盈利的API服务市场",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node demo.js",
    "monitor": "node scripts/service_monitor.js",
    "market-analysis": "python3 scripts/market_analysis.py",
    "generate-project": "python3 scripts/project_generator.py",
    "daily-report": "python3 scripts/daily_report.js",
    "pm2:start": "pm2 start server.js --name x402-api-service",
    "pm2:stop": "pm2 stop x402-api-service",
    "pm2:restart": "pm2 restart x402-api-service",
    "pm2:logs": "pm2 logs x402-api-service",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [
    "api",
    "marketplace",
    "x402",
    "micro-payment",
    "web3",
    "base-chain",
    "file-conversion",
    "image-processing"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.48.2",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/express": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "pdf-lib": "^1.17.1",
    "mammoth": "^1.6.0",
    "xlsx": "^0.18.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/x402-api-marketplace.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/x402-api-marketplace/issues"
  },
  "homepage": "https://github.com/yourusername/x402-api-marketplace#readme"
}